# Runtime
NODE_ENV=production
PORT=3000

# Database (MySQL)
DATABASE_URL=mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME

# Auth / session
JWT_SECRET=replace_with_long_random_secret
OAUTH_SERVER_URL=https://your-oauth-server.example.com
OWNER_OPEN_ID=replace_with_owner_open_id
VITE_APP_ID=replace_with_app_id

# CMS admin login (required if you want to use admin login)
CMS_ADMIN_EMAIL=admin@example.com
CMS_ADMIN_PASSWORD=replace_with_strong_password

# Forge proxy APIs (required by storage, maps, data API, and voice/image features)
BUILT_IN_FORGE_API_URL=https://your-forge-api.example.com
BUILT_IN_FORGE_API_KEY=replace_with_forge_api_key
